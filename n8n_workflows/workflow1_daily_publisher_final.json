        "jsCode": "const uploadResponse = $input.first().json;\nconst fileName = $('Find Next Video').first().json.file_name;\nconst now = new Date();\nconst publishDate = new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate(), 17, 0, 0));\n\nreturn [{\n  media_id: uploadResponse.id || uploadResponse.assetId || uploadResponse.fileId,\n  media_path: uploadResponse.path || uploadResponse.url,\n  file_name: fileName,\n  publish_date: publishDate.toISOString()\n}];"
