    {
      "parameters": {
        "jsCode": "const rows = $input.all();\nlet nextVideo = null;\nlet nextIndex = -1;\n\nfor (let i = 0; i < rows.length; i++) {\n  const d = rows[i].json;\n  if (d.status === 'new' || d.status === 'failed') {\n    nextVideo = d;\n    nextIndex = i;\n    break;\n  }\n}\n\nif (!nextVideo) {\n  return [{ noVideos: true, message: 'No pending videos in queue' }];\n}\n\nreturn [{\n  noVideos: false,\n  file_name: nextVideo.file_name,\n  drive_file_id: nextVideo.drive_file_id,\n  row_number: nextIndex + 2\n}];"
      },
