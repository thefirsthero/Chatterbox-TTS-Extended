        "jsCode": "const igData = $input.all()[0]?.json || {};\nlet ytData = {}, ttData = {};\ntry { ytData = $('Post to YouTube Shorts').first()?.json || {}; } catch(e) {}\ntry { ttData = $('Post to TikTok (Sandbox)').first()?.json || {}; } catch(e) {}\nconst videoInfo = $('Prepare Post Data').first()?.json || {};\n\nreturn [{\n  success: true,\n  file_name: videoInfo.file_name || 'unknown',\n  instagram_post_id: igData.postId || 'not posted',\n  youtube_post_id: ytData.postId || 'not posted',\n  tiktok_post_id: ttData.postId || 'not posted',\n  processed_date: new Date().toISOString()\n}];"
